<% pageName = "Comments" %>
<%- include("head") -%>
<% for (comment of comments) { %>
<article>
  <div>
    <form action="/commentVote/<%= comment.id %>?redirect=/comments/<%= comment.id %>" method="post">
      <button class="<%= comment.voted ? 'outline' : '' %>">
        <%- include("icons/upvoteArrow") -%>
        <%= comment.votes %>
      </button>
    </form>
    <span><%= dateFormat(comment.createdAt) %></span>
    <span>
      by
      <a href="/users/<%= comment.UserId %>">
        <%- comment.User.identicon -%>
        <%= comment.User.name %>
      </a>
    </span>
    <span>on <a href="/posts/<%= comment.PostId %>"><%= comment.Post.title %></a>
    </span>
  </div>
  <% for (paragraph of comment.text.split("\r\n\r\n")) { %>
  <p><%= paragraph %></p>
  <% } %>
</article>
<% } %>
<% if (offset + limit < count) { %>
<a href="?offset=<%= offset + limit %>">
  <button type="button">More <%- include ("icons/right") -%></button>
</a>
<% } %>
<%- include("foot") -%>