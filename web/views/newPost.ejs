<% pageName = "New post" %>
<%- include("head") -%>
<form method="post">
  <h2>New post</h2>
  <p>
    The title and category must be filled. The link and link type; or the text
    field must be filled.
  </p>
  <label>
    Title
    <input type="text" name="title" value="<%= title %>" required>
  </label>
  <label>
    Link
    <input type="text" name="link" value="<%= link %>">
  </label>
  <label>
    Link type
    <p><small>It's recommended to use one of the listed link types.</small></p>
    <%- include("linkTypes") -%>
    <input type="text" name="linkType" value="<%= linkType %>" list="linkTypes">
  </label>
  <label>
    Text
    <textarea name="text" rows="5"><%= text %></textarea>
  </label>
  <label>
    Category
    <p><small>It's recommended to use one of the listed categories.</small></p>
    <%- include("categories") -%>
    <input type="text" name="category" value="<%= category %>" list="categories" required>
  </label>
  <% if (typeof(msg) != "undefined") { %>
  <mark class="msg"><%= msg %></mark>
  <% } %> <% if (typeof(msg_fail) != "undefined") { %>
  <mark class="msg msg-fail"><%= msg_fail %></mark>
  <% } %>
  <button type="submit">Submit</button>
</form>
<%- include("foot") -%>