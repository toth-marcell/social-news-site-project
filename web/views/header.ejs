<header class="container">
  <nav>
    <ul>
      <li>
        <h1>
          <%- include("../public/logo.svg") -%>
          <a href="/"><%= siteName %></a>
        </h1>
      </li>
    </ul>
    <ul>
      <li>
        <a href="/">hot</a>
      </li>
      <li>
        <a href="/new">new</a>
      </li>
      <li>
        <a href="/top">top</a>
      </li>
      <% if (user) { %>
      <li>
        <a href="/newpost"><button>New post</button></a>
      </li>
      <% if (user.isAdmin ) { %>
      <li>
        <a href="/admin/logs"><button class="contrast">Logs</button></a>
      </li>
      <li>
        <a href="/admin/users"><button class="contrast">Users</button></a>
      </li>
      <% } %>
      <% } %>
    </ul>
    <ul>
      <% if (user) { %>
      <li>
        Logged in as
        <a href="/users/<%= user.id %>">
          <%- user.identicon -%>
          <%= user.name %>
        </a>
        (<%= user.get("points") %> points)
      </li>
      <li>
        <a href="/logout"><button>Log out</button></a>
      </li>
      <% } else { %>
      <li>
        <a href="/register"><button>Register</button></a>
      </li>
      <li>
        <a href="/login"><button>Log in</button></a>
      </li>
      <% } %>
    </ul>
  </nav>
</header>