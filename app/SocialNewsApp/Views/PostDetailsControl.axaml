<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SocialNewsApp.Views.PostDetailsControl"
			 xmlns:m="using:SocialNewsApp.Models"
			 xmlns:v="using:SocialNewsApp.Views"
			 x:DataType="m:PostWithComments">
	<Design.DataContext>
		<m:PostWithComments/>
	</Design.DataContext>
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<StackPanel Orientation="Horizontal" Spacing="5">
			<Button Content="{Binding Votes, StringFormat=⬆ {0}}" VerticalAlignment="Center" IsVisible="{Binding Voted}" Opacity=".5" Command="{Binding UpvoteCommand}"/>
			<Button Content="{Binding Votes, StringFormat=⬆ {0}}" VerticalAlignment="Center" IsVisible="{Binding !Voted}" Command="{Binding UpvoteCommand}"/>
			<SelectableTextBlock Text="{Binding Category}" VerticalAlignment="Center" />
			<SelectableTextBlock Text="{Binding CreatedAt}" VerticalAlignment="Center"/>
			<SelectableTextBlock Text="{Binding User.Name, StringFormat=by {0}}" VerticalAlignment="Center"/>
		</StackPanel>
		<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5">
			<SelectableTextBlock Text="{Binding Title}" FontSize="20" VerticalAlignment="Center"/>
			<SelectableTextBlock Text="{Binding LinkType}" VerticalAlignment="Center"/>
			<HyperlinkButton Content="{Binding Link}" NavigateUri="{Binding Link}" VerticalAlignment="Center"/>
		</StackPanel>
		<SelectableTextBlock Grid.Row="2" Text="{Binding Text}"/>
		<StackPanel Grid.Row="3" IsVisible="{Binding IsLoggedIn}">
			<Label>New comment</Label>
			<TextBox AcceptsReturn="True" Text="{Binding CommentField}"/>
			<Button HorizontalAlignment="Right" Command="{Binding SubmitCommentCommand}" CommandParameter="{Binding CommentField}">Submit</Button>
		</StackPanel>
		<ScrollViewer Grid.Row="4">
			<ItemsControl ItemsSource="{Binding Comments}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<v:CommentControl/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
