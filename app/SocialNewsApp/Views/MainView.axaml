<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SocialNewsApp.ViewModels"
			 xmlns:m="using:SocialNewsApp.Models"
			 xmlns:v="using:SocialNewsApp.Views"
			 xmlns:materialIcons="using:Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SocialNewsApp.Views.MainView"
             x:DataType="vm:MainViewModel">
	<Design.DataContext>
		<vm:MainViewModel/>
	</Design.DataContext>
	<Grid>
		<!--Main page-->
		<Grid IsVisible="{Binding IsMainActive}">
			<Grid.RowDefinitions>
				<RowDefinition Height="auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>
			<ScrollViewer HorizontalScrollBarVisibility="Auto" MinHeight="50">
				<Menu VerticalAlignment="Top">
					<MenuItem Command="{Binding RefreshPostsCommand}" Header="_Refresh"/>
					<MenuItem Header="{Binding PostSort, StringFormat=_Sorting by {0}}">
						<MenuItem Header="_hot" Command="{Binding ChangeSortCommand}" CommandParameter="hot"/>
						<MenuItem Header="_new" Command="{Binding ChangeSortCommand}" CommandParameter="new"/>
						<MenuItem Header="_top" Command="{Binding ChangeSortCommand}" CommandParameter="top"/>
					</MenuItem>
					<Separator Height="NaN" Width="1" IsVisible="{Binding IsLoggedIn}"/>
					<MenuItem Command="{Binding NewPostCommand}" Header="_New post" IsVisible="{Binding IsLoggedIn}"/>
					<Separator Height="NaN" Width="1"/>
					<MenuItem Command="{Binding LogInOrRegisterCommand}" Header="_Log in or register" IsVisible="{Binding !IsLoggedIn}"/>
					<MenuItem IsEnabled="False" IsVisible="{Binding IsLoggedIn}">
						<MenuItem.Header>
							<StackPanel Orientation="Horizontal" Spacing="5">
								<TextBlock VerticalAlignment="Center">Logged in as</TextBlock>
								<Svg Source="{Binding CurrentUser.Identicon}" MaxHeight="25"/>
								<TextBlock VerticalAlignment="Center" Text="{Binding CurrentUser.Name}"/>
								<TextBlock VerticalAlignment="Center" Text="{Binding CurrentUser.Points, StringFormat=({0} points)}"/>
							</StackPanel>
						</MenuItem.Header>
					</MenuItem>
					<MenuItem Command="{Binding LogOutCommand}" Header="_Log out" IsVisible="{Binding IsLoggedIn}"/>
				</Menu>
			</ScrollViewer>
			<StackPanel Grid.Row="1" Margin="10">
				<ItemsControl ItemsSource="{Binding CurrentPage.Posts}">
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="m:Post">
							<v:PostControl Margin="0,0,0,10"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
				<Button HorizontalAlignment="Center" Margin="5" Command="{Binding NextPageCommand}" IsVisible="{Binding CurrentPage.IsNextPageAvailable}">More</Button>
			</StackPanel>
		</Grid>
		<!--Post details page-->
		<Grid IsVisible="{Binding IsPostDetailsActive}">
			<Grid.RowDefinitions>
				<RowDefinition Height="auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>
			<Menu>
				<MenuItem Command="{Binding BackCommand}">
					<MenuItem.Header>
						<StackPanel Orientation="Horizontal" Spacing="5">
							<materialIcons:MaterialIcon Kind="ArrowLeft"/>
							<TextBlock VerticalAlignment="Center">Back</TextBlock>
						</StackPanel>
					</MenuItem.Header>
				</MenuItem>
			</Menu>
			<v:PostDetailsControl Grid.Row="1" DataContext="{Binding OpenPost}"/>
		</Grid>
		<!--Login or register page-->
		<Grid Margin="10" RowSpacing="5" IsVisible="{Binding IsLoginOrRegisterActive}" MaxWidth="500">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="auto"/>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition/>
				<RowDefinition Height="auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>
			<Label HorizontalAlignment="Right" VerticalAlignment="Bottom">Name</Label>
			<TextBox Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Name}" VerticalAlignment="Bottom"/>
			<Label Grid.Row="1" HorizontalAlignment="Right">Password</Label>
			<TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Password}" PasswordChar="*"/>
			<Button Grid.Row="2" Command="{Binding BackCommand}" VerticalAlignment="Top">Cancel</Button>
			<StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
				<Button Command="{Binding LogInCommand}">Log in</Button>
				<Button Command="{Binding RegisterCommand}">Register</Button>
			</StackPanel>
		</Grid>
		<!--Post editor-->
		<Grid IsVisible="{Binding IsPostEditorActive}">
			<Grid.RowDefinitions>
				<RowDefinition Height="auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>
			<Menu>
				<MenuItem Command="{Binding BackCommand}">
					<MenuItem.Header>
						<StackPanel Orientation="Horizontal" Spacing="5">
							<materialIcons:MaterialIcon Kind="ArrowLeft"/>
							<TextBlock VerticalAlignment="Center">Back</TextBlock>
						</StackPanel>
					</MenuItem.Header>
				</MenuItem>
			</Menu>
			<v:PostEditorControl Grid.Row="1" DataContext="{Binding PostEditorViewModel}"/>
		</Grid>
	</Grid>
</UserControl>
